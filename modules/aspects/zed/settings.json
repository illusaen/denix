{
  "project_panel": {
    "git_status_indicator": false,
    "entry_spacing": "standard",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "git_panel": {
    "button": true,
  },
  "terminal": {
    "dock": "right",
    "copy_on_select": true,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "code_lens": "on",
  "preferred_line_length": 120,
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "vim": {
    "gdefault": true,
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "scrollbar": {
    "show": "never",
  },
  "diff_view_style": "unified",
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "ui_font_family": "@sans@",
  "buffer_line_height": "standard",
  "buffer_font_weight": 500.0,
  "buffer_font_family": "@mono@",
  "auto_update": false,
  "colorize_brackets": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "on_last_window_closed": "quit_app",
  "ui_font_size": 18.0,
  "buffer_font_size": 16.0,
  "semantic_tokens": "combined",
  "theme": {
    "mode": "system",
    "light": "@theme-light@",
    "dark": "@theme-dark@",
  },
  "load_direnv": "shell_hook",
  "auto_install_extensions": {
    "html": true,
    "fish": true,
    "lua": true,
    "kdl": true,
    "nix": true,
    "svelte": true,
    "svelte-mcp": true,
    "toml": true,
    "catppuccin-icons": true,
  },
  "agent_servers": {
    "Codex ACP (Nix)": {
      "type": "custom",
      "command": "/run/current-system/sw/bin/codex-acp",
      "args": [],
      "env": {},
    },
  },
  "languages": {
    "CSS": {
      "language_servers": ["tailwindcss-intellisense-css", "!vscode-css-language-server", "..."],
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "svelte": "html",
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class:\\s*([^\\s{]+)",
            "\\{\\s*class:\\s*\"([^\"]*)\"",
            "\\{\\s*class:\\s*'([^']*)'",
          ],
        },
      },
    },
  },
}
